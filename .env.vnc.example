# =============================================================================
# Linux微信 + VNC Docker 环境变量配置示例
# 复制为 .env.vnc 并根据实际情况修改
# =============================================================================

# =============================================================================
# VNC访问配置
# =============================================================================

# VNC密码（必填）
VNC_PASSWORD=your_secure_vnc_password

# 仅查看密码（可选，不设置则无仅查看模式）
VNC_VIEWONLY_PASSWORD=

# 外部访问端口
VNC_EXTERNAL_PORT=5901
NOVNC_EXTERNAL_PORT=6080

# 分辨率设置
VNC_RESOLUTION=1280x800
VNC_COL_DEPTH=24

# =============================================================================
# 微信支付服务配置
# =============================================================================

# 回调URL（必填）- 你的业务系统接收地址
CALLBACK_URL=http://your-server:5000/api/payment/notify/linux_wechat

# 回调签名密钥（必填）
CALLBACK_SECRET=your_secret_key_here

# API端口映射
API_PORT=8888
ADMIN_PORT=8889

# =============================================================================
# 微信数据库解密配置
# =============================================================================

# 解密项目目录（主机路径）
WECHAT_DECRYPT_DIR=./data/decrypt

# =============================================================================
# 可选：Nginx反向代理配置
# =============================================================================

# 启用Nginx（使用 docker-compose --profile with-nginx up）
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# 系统配置
# =============================================================================

# 时区
TZ=Asia/Shanghai
